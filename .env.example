PORT=3000
NODE_ENV=production

# PostgreSQL (Railway fornece DATABASE_URL automaticamente)
DATABASE_URL=postgresql://user:pass@localhost:5432/barbearia
# Ou use variáveis separadas:
PGHOST=localhost
PGPORT=5432
PGDATABASE=barbearia
PGUSER=postgres
PGPASSWORD=senha

# JWT
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_min_32_chars
JWT_EXPIRES_IN=7d

# Configurações da aplicação
FRONTEND_URL=http://localhost:3000
SEED_ON_START=true
